# Copy to .env and fill in. NEVER commit your real .env — it is git-ignored.

# --- AWS credentials (standard chain) -------------------------------------
# Prefer a named profile or an instance/role profile over static keys.
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- AWS MCP Server settings ----------------------------------------------
# Block all mutating actions when true (recommended).
AWS_MCP_READ_ONLY=true

# Comma-separated list of services to enable (available: s3, ec2, lambda).
AWS_MCP_ENABLED_SERVICES=s3,ec2,lambda

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
AWS_MCP_LOG_LEVEL=INFO

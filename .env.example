AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLED_SERVICES=ec2,s3,lambda,dynamodb,rds,iam
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
CACHE_TTL=300

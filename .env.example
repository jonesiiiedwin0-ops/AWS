# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PROFILE=

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Service Configuration
ENABLED_SERVICES=ec2,s3,lambda,dynamodb,rds,iam

# Performance Configuration
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
CACHE_TTL=300
